# EC2 / global deployment — copy to .env on the server (never commit .env).
# AWS auth: use EC2 instance IAM role (recommended). Do not bake keys into the image.

RAG_BACKEND=aws_kb
AWS_REGION=us-east-1

BEDROCK_KB_ID=
BEDROCK_DATA_SOURCE_ID=
BEDROCK_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/amazon.nova-lite-v1:0
AWS_KB_TOP_K=5
AWS_KB_RETRIEVE_CANDIDATES=30
AWS_KB_CONTEXT_SOURCE_LIMIT=10
AWS_KB_MAX_CHUNKS_PER_SOURCE=2
AWS_KB_CONTEXT_EXCERPT_MAX=1200
AWS_KB_MIN_SCORE=

AWS_S3_BUCKET=
AWS_S3_PREFIX=scoutmatch/knowledge-base/

FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

MAX_UPLOAD_MB=25

# Not used when RAG_BACKEND=aws_kb:
# GEMINI_API_KEY=
# HF_TOKEN=
